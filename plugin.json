{
  "id": "nodebb-plugin-cp-wukong-topic-chat",
  "name": "CP Wukong Topic Chat",
  "description": "Topic page chat plugin for selected NodeBB categories with separated client JavaScript and SCSS.",
  "url": "https://github.com/Hurt56631-ai/nodebb-plugin-cp-wukong-topic-chat",
  "library": "./library.js",
  "languages": "languages",
  "staticDirs": {
    "static": "./static",
    "public": "./public"
  },
  "templates": "./templates",
  "scripts": [
    "public/lib/topic-chat.js",
    "public/lib/category-activity-sort.js"
  ],
  "scss": [
    "scss/topic-chat-ui.scss"
  ],
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "filter:config.get",
      "method": "getConfig"
    }
  ]
}
