<div class="cp-wukong-topic-chat" data-cp-wukong-topic-chat>
  <div class="cp-wukong-topic-chat__header">
    <h2 class="cp-wukong-topic-chat__title">[[cp-wukong-topic-chat:title]]</h2>

    <div class="cp-wukong-topic-chat__status" data-cp-wukong-topic-chat-status>
      <span class="cp-wukong-topic-chat__status-dot is-disconnected" aria-hidden="true"></span>
      <span>[[cp-wukong-topic-chat:connecting]]</span>
    </div>
  </div>

  <div class="cp-wukong-topic-chat__body" data-cp-wukong-topic-chat-body>
    <div class="cp-wukong-topic-chat__loading">
      [[cp-wukong-topic-chat:loading]]
    </div>
  </div>

  <form class="cp-wukong-topic-chat__composer" data-cp-wukong-topic-chat-composer>
    <input
      class="cp-wukong-topic-chat__input"
      type="text"
      name="message"
      autocomplete="off"
      placeholder="[[cp-wukong-topic-chat:placeholder]]"
      aria-label="[[cp-wukong-topic-chat:placeholder]]"
    />

    <button class="cp-wukong-topic-chat__button" type="submit">
      [[cp-wukong-topic-chat:send]]
    </button>
  </form>
</div>
